<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="IBMShopZ_MasterSuite" verbose="2" parallel="methods" thread-count="3" data-provider-thread-count="3">

    <listeners>
        <listener class-name="com.ibm.shopz.listeners.TestNGListener"/>
    </listeners>

    <test name="IBMShopZ_SmokeTests" preserve-order="true">
        <groups><run><include name="smoke"/></run></groups>
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.ibm.shopz.tests.SmokeTest"/>
        </classes>
    </test>

    <test name="IBMShopZ_ProductCatalogTests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes><class name="com.ibm.shopz.tests.ProductCatalogPageTest"/></classes>
    </test>

    <test name="IBMShopZ_FmidDetailTests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes><class name="com.ibm.shopz.tests.FmidDetailPageTest"/></classes>
    </test>

    <test name="IBMShopZ_ProductDetailTests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes><class name="com.ibm.shopz.tests.ProductDetailPageTest"/></classes>
    </test>

    <test name="IBMShopZ_NavigationTests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes><class name="com.ibm.shopz.tests.NavigationTest"/></classes>
    </test>

    <test name="IBMShopZ_FilterCombinationTests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes><class name="com.ibm.shopz.tests.FilterCombinationTest"/></classes>
    </test>

    <test name="IBMShopZ_UIValidationTests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes><class name="com.ibm.shopz.tests.UIValidationTest"/></classes>
    </test>

    <test name="IBMShopZ_PageRefreshTests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes><class name="com.ibm.shopz.tests.PageRefreshAndResetTest"/></classes>
    </test>

    <test name="IBMShopZ_DropdownBoundaryTests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes><class name="com.ibm.shopz.tests.DropdownBoundaryTest"/></classes>
    </test>

    <test name="IBMShopZ_SearchResultsValidationTests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes><class name="com.ibm.shopz.tests.SearchResultsValidationTest"/></classes>
    </test>

    <test name="IBMShopZ_AccessibilityPerformanceTests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes><class name="com.ibm.shopz.tests.AccessibilityAndPerformanceTest"/></classes>
    </test>

    <test name="IBMShopZ_E2EJourneyTests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes><class name="com.ibm.shopz.tests.EndToEndJourneyTest"/></classes>
    </test>

</suite>
