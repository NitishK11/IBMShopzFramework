<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    IBM ShopZ - End-to-End Test Suite
    Run: mvn test -Dsurefire.suiteXmlFiles=src/test/resources/testng-e2e.xml
-->

<suite name="IBMShopZ_E2ESuite" verbose="2">

    <listeners>
        <listener class-name="com.ibm.shopz.listeners.TestNGListener"/>
    </listeners>

    <test name="E2ETests">
        <groups>
            <run>
                <include name="e2e"/>
            </run>
        </groups>
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.ibm.shopz.tests.ProductDetailPageTest"/>
        </classes>
    </test>

</suite>
