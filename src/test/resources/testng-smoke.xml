<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    IBM ShopZ - Smoke Test Suite Only
    Run: mvn test -Dsurefire.suiteXmlFiles=src/test/resources/testng-smoke.xml
-->

<suite name="IBMShopZ_SmokeSuite" verbose="2">

    <listeners>
        <listener class-name="com.ibm.shopz.listeners.TestNGListener"/>
    </listeners>

    <test name="SmokeTests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.ibm.shopz.tests.SmokeTest"/>
            <class name="com.ibm.shopz.tests.ProductCatalogPageTest"/>
            <class name="com.ibm.shopz.tests.NavigationTest"/>
        </classes>
    </test>

</suite>
